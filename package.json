{
  "name": "@dickless/sdk",
  "version": "0.1.0",
  "description": "Official SDK for the dickless.io API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "dependencies": { "@dl-io/shared": "workspace:*" },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7"
  },
  "license": "MIT"
}
